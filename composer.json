{
    "name": "saygoweb/anorm",
    "description": "Another ORM for PHP",
    "type": "library",
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "php-coveralls/php-coveralls": "^2.1",
        "squizlabs/php_codesniffer": "^3.7",
        "phpstan/phpstan": "^1.10"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "cambell",
            "email": "cambell.prince@gmail.com"
        }
    ],
    "require": {
        "wp-cli/php-cli-tools": "^0.11.10"
    },
    "autoload": {
        "psr-4": {
            "Anorm\\Test\\": "test/anorm/",
            "Anorm\\Tools\\": "tools/src/",
            "Anorm\\": "src/"
        }
    },
    "bin": ["bin/anorm.php"],
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html build/coverage --coverage-text",
        "test:quick": "phpunit -c phpunit-no-coverage.xml",
        "test:ci": "phpunit --coverage-clover=build/logs/clover.xml",
        "cs:check": "phpcs",
        "cs:fix": "phpcbf",
        "analyze": "phpstan analyse src/ test/ --level=5 --memory-limit=512M",
        "quality": [
            "@cs:check",
            "@analyze"
        ],
        "ci": [
            "@test:ci",
            "@quality"
        ]
    }
}
